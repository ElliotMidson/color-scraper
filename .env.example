# Copy to `.env.local` for local dev (Next.js loads it automatically).
# https://nextjs.org/docs/app/guides/environment-variables

# AI brand analysis (POST /api/analyze-brand): set OpenAI and/or Anthropic.
# If both are set, OpenAI is used unless you set BRAND_AI_PROVIDER=anthropic

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Claude (Anthropic) — use this instead of OpenAI if you prefer
ANTHROPIC_API_KEY=
# Alias for the same key:
# CLAUDE_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# Optional: openai | anthropic | claude (when both API keys are set)
# BRAND_AI_PROVIDER=anthropic
